Dialogue: 0,0:00:00.02,0:00:02.08,Default,,0,0,0,,sebuah tragedi besar menghantam perusahaan ini
Dialogue: 0,0:00:02.61,0:00:04.61,Default,,0,0,0,,Pabrik utama Jarum di Kudus ludes terbakar
Dialogue: 0,0:00:04.61,0:00:04.94,Default,,0,0,0,,hebat
Dialogue: 0,0:00:05.52,0:00:07.96,Default,,0,0,0,,Dalam dunia manufaktur kebakaran pabrik adalah mimpi
Dialogue: 0,0:00:07.96,0:00:10.60,Default,,0,0,0,,buruk paling mengerikan karena itu berarti hilangnya
Dialogue: 0,0:00:10.60,0:00:14.13,Default,,0,0,0,,aset produksi terhentinya pemasukan dan ancaman kebangkrutan
Dialogue: 0,0:00:14.13,0:00:16.33,Default,,0,0,0,,seketika Banyak perusahaan pada masa itu tidak
Dialogue: 0,0:00:16.33,0:00:18.75,Default,,0,0,0,,mampu bangkit ketika menghadapi krisis serupa
Dialogue: 0,0:00:19.32,0:00:21.58,Default,,0,0,0,,tapi seolah belum cukup menderita Tidak lama
Dialogue: 0,0:00:21.58,0:00:24.02,Default,,0,0,0,,setelah kebakaran itu sang pendiri W W
Dialogue: 0,0:00:24.02,0:00:27.22,Default,,0,0,0,,Gwen pun meninggal dunia Tongkat Estafet kepemimpinan
Dialogue: 0,0:00:27.22,0:00:29.30,Default,,0,0,0,,akhirnya beralih ke tangan dua putranya yang
Dialogue: 0,0:00:29.30,0:00:31.80,Default,,0,0,0,,masih sangat muda yaitu Budi Hartono dan
Dialogue: 0,0:00:31.80,0:00:32.50,Default,,0,0,0,,Michael Hartono
Dialogue: 0,0:00:33.13,0:00:35.13,Default,,0,0,0,,Transisi generasi dalam kondisi krisis seperti ini
Dialogue: 0,0:00:35.13,0:00:37.17,Default,,0,0,0,,adalah salah satu momen paling beresiko
Dialogue: 0,0:00:37.82,0:00:40.17,Default,,0,0,0,,Banyak bisnis keluarga yang hancur berantakan Ketika
Dialogue: 0,0:00:40.17,0:00:42.77,Default,,0,0,0,,menghadapi krisis ganda seperti yang dihadapi jarum
Dialogue: 0,0:00:43.17,0:00:46.11,Default,,0,0,0,,Namun disinilah mentalitas baja Hartono bersaudara itu
Dialogue: 0,0:00:46.11,0:00:46.53,Default,,0,0,0,,teruji
Dialogue: 0,0:00:47.08,0:00:49.02,Default,,0,0,0,,Alih alih menyerah dan menutup usaha mereka
Dialogue: 0,0:00:49.02,0:00:51.50,Default,,0,0,0,,justru memilih jalan yang sangat berani dengan
Dialogue: 0,0:00:51.50,0:00:54.83,Default,,0,0,0,,mengambil keputusan rekonstruksi agresif Kakak beradik itu
Dialogue: 0,0:00:54.83,0:00:56.77,Default,,0,0,0,,tidak hanya membangun ulang pabrik secara fisik
Dialogue: 0,0:00:57.16,0:01:00.19,Default,,0,0,0,,tetapi juga melakukan pengorganisasian ulang manajemen dan
Dialogue: 0,0:01:00.19,0:01:02.96,Default,,0,0,0,,strategi produksinya untuk mengubah cara kerja jarum
Dialogue: 0,0:01:02.96,0:01:03.50,Default,,0,0,0,,kedepannya
Dialogue: 0,0:01:04.05,0:01:06.74,Default,,0,0,0,,Pasca kebakaran Hartono bersaudara itu memang melakukan
Dialogue: 0,0:01:06.74,0:01:10.24,Default,,0,0,0,,lompatan besar yang ternyata berhasil mengubah nasib
Dialogue: 0,0:01:10.24,0:01:11.02,Default,,0,0,0,,keluarga mereka