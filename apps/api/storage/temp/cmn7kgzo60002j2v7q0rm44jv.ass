Dialogue: 0,0:00:00.04,0:00:03.01,Default,,0,0,0,,struktural kekayaan Hartono bersaudara bos pemilik grup
Dialogue: 0,0:00:03.01,0:00:05.33,Default,,0,0,0,,bisnis jarum sebenarnya dimulai di sebuah kota
Dialogue: 0,0:00:05.33,0:00:06.44,Default,,0,0,0,,kecil bernama Kudus
Dialogue: 0,0:00:07.00,0:00:08.95,Default,,0,0,0,,Kota itulah yang sejak awal abad ke
Dialogue: 0,0:00:08.95,0:00:11.62,Default,,0,0,0,,20 sudah menyandang gelar kota kretek Di
Dialogue: 0,0:00:11.62,0:00:13.83,Default,,0,0,0,,Kudus rokok cengkeh bukan hanya barang dagangan
Dialogue: 0,0:00:14.19,0:00:16.73,Default,,0,0,0,,tetapi sudah menjadi urat nadi kehidupan masyarakat
Dialogue: 0,0:00:16.73,0:00:19.37,Default,,0,0,0,,mesin penggerak ekonomi lokal dan identitas industri
Dialogue: 0,0:00:19.37,0:00:22.69,Default,,0,0,0,,nasional yang sangat kuat Pada tahun 1951
Dialogue: 0,0:00:22.86,0:00:25.80,Default,,0,0,0,,ayah Hartono bersaudara itu Oiwi Gwen memutuskan
Dialogue: 0,0:00:25.80,0:00:28.13,Default,,0,0,0,,untuk membeli merek dan lisensi sebuah perusahaan
Dialogue: 0,0:00:28.13,0:00:31.05,Default,,0,0,0,,rokok kecil bernama Jarum Gramophone yang nyaris
Dialogue: 0,0:00:31.05,0:00:33.30,Default,,0,0,0,,bangkrut Saat itu Jarum hanyalah pemain kecil
Dialogue: 0,0:00:33.30,0:00:36.24,Default,,0,0,0,,di tengah raksasa raksasa kretek lainnya Produksinya
Dialogue: 0,0:00:36.24,0:00:39.10,Default,,0,0,0,,masih dilakukan secara manual dengan tangan distribusinya
Dialogue: 0,0:00:39.10,0:00:40.91,Default,,0,0,0,,pun masih sangat terbatas di sekitar Jawa
Dialogue: 0,0:00:40.91,0:00:43.82,Default,,0,0,0,,Tengah dan posisinya di pasar belum ada
Dialogue: 0,0:00:43.82,0:00:46.08,Default,,0,0,0,,apa apanya Namun ada satu hal cerdik
Dialogue: 0,0:00:46.08,0:00:48.83,Default,,0,0,0,,yang dilakukan Oiwi Gwen yaitu ia tidak
Dialogue: 0,0:00:48.83,0:00:50.80,Default,,0,0,0,,membangun bisnis dari nol di lahan kosong
Dialogue: 0,0:00:51.19,0:00:53.05,Default,,0,0,0,,Ia sengaja masuk ke dalam ekosistem industri
Dialogue: 0,0:00:53.05,0:00:54.30,Default,,0,0,0,,yang sudah matang di Kudus
Dialogue: 0,0:00:54.91,0:00:57.27,Default,,0,0,0,,Gwen memanfaatkan jaringan tenaga kerja yang sudah
Dialogue: 0,0:00:57.27,0:00:58.00,Default,,0,0,0,,ahli melinting
Dialogue: 0,0:00:58.53,0:01:00.46,Default,,0,0,0,,akses bahan beku cengkeh yang melimpah dan
Dialogue: 0,0:01:00.46,0:01:02.53,Default,,0,0,0,,yang paling penting adalah ia masuk ke
Dialogue: 0,0:01:02.53,0:01:04.41,Default,,0,0,0,,industri yang memiliki permintaan stabil
Dialogue: 0,0:01:04.97,0:01:07.27,Default,,0,0,0,,Dalam dunia bisnis rokok memang menjadi komoditas
Dialogue: 0,0:01:07.27,0:01:07.55,Default,,0,0,0,,unik
Dialogue: 0,0:01:08.10,0:01:10.36,Default,,0,0,0,,Barang itu memiliki sifat repeat demand atau
Dialogue: 0,0:01:10.36,0:01:13.05,Default,,0,0,0,,pembelian berulang yang luar biasa tinggi Sekali
Dialogue: 0,0:01:13.05,0:01:15.17,Default,,0,0,0,,orang cocok dengan rasanya mereka akan terus
Dialogue: 0,0:01:15.17,0:01:17.91,Default,,0,0,0,,membeli setiap hari Inilah yang secara struktural
Dialogue: 0,0:01:17.91,0:01:20.74,Default,,0,0,0,,menjadikan Jarum sebagai mesin pencetak uang yang
Dialogue: 0,0:01:20.74,0:01:23.00,Default,,0,0,0,,sangat tangguh bahkan di tengah badai ekonomi
Dialogue: 0,0:01:23.00,0:01:23.55,Default,,0,0,0,,sekalipun
Dialogue: 0,0:01:24.10,0:01:24.72,Default,,0,0,0,,Perjalanan menuju